<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SiteCriativos — Sites Profissionais + Gestão Inteligente para Comerciantes</title>
    <meta name="description" content="Sites profissionais a partir de R$450 e Gestão Inteligente por R$80/mês. Transforme seu comércio local em máquina de vendas.">
    <meta property="og:title" content="SiteCriativos — Sites Profissionais para Comerciantes">
    <meta property="og:description" content="Sites a partir de R$450 + Gestão Inteligente R$80/mês. Aumente suas vendas agora.">
    <meta property="og:type" content="website">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--roxo-escuro:#1a103c;--indigo:#4f46e5;--violeta:#7c3aed;--branco:#ffffff;--cinza-claro:#f8f9fc;--cinza-texto:#5a5d6e;--titulo-escuro:#1a103c;--whatsapp:#25D366;--whatsapp-hover:#1ebe5b;--sombra:0 12px 32px rgba(79,70,229,0.06);--sombra-hover:0 20px 48px rgba(79,70,229,0.14);--raio:20px;--transicao:all .35s cubic-bezier(.4,0,.2,1);--bounce:all .45s cubic-bezier(.175,.885,.32,1.275)}
        html{scroll-behavior:smooth;font-size:16px}
        body{font-family:'Poppins',sans-serif;background:var(--branco);color:var(--cinza-texto);line-height:1.6;overflow-x:hidden}
        .container{width:100%;max-width:1200px;margin:0 auto;padding:0 24px}
        ::-webkit-scrollbar{width:8px}
        ::-webkit-scrollbar-track{background:#f1f1f1}
        ::-webkit-scrollbar-thumb{background:linear-gradient(var(--indigo),var(--violeta));border-radius:10px}
        .header{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:14px 0;background:rgba(255,255,255,.88);backdrop-filter:blur(20px);transition:var(--transicao)}
        .header.scrolled{background:rgba(255,255,255,.97);box-shadow:0 4px 30px rgba(0,0,0,.1)}
        .header .container{display:flex;align-items:center;justify-content:space-between}
        .logo{display:flex;align-items:center;gap:10px;text-decoration:none}
        .logo__icon{width:44px;height:44px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:14px;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:20px;font-weight:800;box-shadow:0 4px 15px rgba(79,70,229,.3)}
        .logo__text{font-size:1.4rem;font-weight:800;color:var(--roxo-escuro)}
        .logo__text span{color:var(--violeta)}
        .nav-links{display:flex;align-items:center;gap:32px}
        .nav-links a{color:var(--titulo-escuro);text-decoration:none;font-weight:600;font-size:.92rem;transition:var(--transicao);position:relative}
        .nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--indigo),var(--violeta));transition:width .3s;border-radius:2px}
        .nav-links a:hover::after{width:100%}
        .btn-nav{padding:10px 26px;background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco)!important;border-radius:50px;font-weight:700;font-size:.9rem;box-shadow:0 4px 18px rgba(124,58,237,.3);text-decoration:none;transition:var(--bounce)}
        .btn-nav:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(124,58,237,.45)}
        .menu-toggle{display:none;background:none;border:none;font-size:1.5rem;color:var(--roxo-escuro);cursor:pointer}
        .hero{padding:170px 0 100px;background:linear-gradient(165deg,#1a103c 0%,#2d1b69 25%,#1e1b4b 55%,#0a0620 100%);position:relative;overflow:hidden;min-height:100vh;display:flex;align-items:center}
        .hero__bg{position:absolute;inset:0}
        .hero__bg::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.04) 1px,transparent 1px);background-size:50px 50px}
        .hero__bg::after{content:'';position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(124,58,237,.15),transparent 70%);top:-200px;right:-200px;border-radius:50%}
        .hero .container{position:relative;z-index:2}
        .hero__badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);padding:8px 20px;border-radius:50px;color:#c4b5fd;font-size:.82rem;font-weight:600;margin-bottom:28px;backdrop-filter:blur(10px)}
        .hero__badge i{color:#a78bfa}
        .hero__title{font-size:clamp(2.4rem,5.5vw,4.2rem);font-weight:900;color:var(--branco);line-height:1.1;margin-bottom:20px;max-width:850px}
        .hero__title .highlight{background:linear-gradient(90deg,#a78bfa,#c4b5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
        .hero__subtitle{font-size:clamp(1.05rem,2vw,1.25rem);color:#b0b8cc;max-width:620px;margin-bottom:40px;line-height:1.7}
        .hero__stats{display:flex;gap:40px;margin-bottom:40px}
        .hero__stat{text-align:left}
        .hero__stat-num{font-size:2rem;font-weight:900;color:var(--branco);line-height:1}
        .hero__stat-num span{font-size:.5em;vertical-align:super;color:#a78bfa}
        .hero__stat-label{font-size:.8rem;color:#8892b0;margin-top:4px;font-weight:500}
        .hero__cta-group{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
        .btn-whatsapp{display:inline-flex;align-items:center;gap:12px;background:linear-gradient(135deg,var(--whatsapp),var(--whatsapp-hover));color:var(--branco);text-decoration:none;padding:18px 40px;border-radius:50px;font-weight:800;font-size:1.1rem;box-shadow:0 10px 40px rgba(37,211,102,.45);transition:var(--bounce)}
        .btn-whatsapp:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 50px rgba(37,211,102,.6)}
        .btn-whatsapp i{font-size:1.3rem}
        .hero__trust{display:flex;align-items:center;gap:12px;color:#8892b0;font-size:.85rem}
        .hero__trust-avatars{display:flex}
        .hero__trust-avatars span{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--indigo),var(--violeta));border:2px solid #1a103c;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:.7rem;font-weight:700;margin-left:-8px}
        .hero__trust-avatars span:first-child{margin-left:0}
        .proof-bar{background:linear-gradient(90deg,var(--indigo),var(--violeta));padding:16px 0;text-align:center;color:var(--branco);font-size:.9rem;font-weight:600}
        .proof-bar i{margin:0 6px;color:#c4b5fd}
        .section-header{text-align:center;margin-bottom:60px}
        .section-header h2{font-size:clamp(1.8rem,4vw,2.6rem);font-weight:800;color:var(--titulo-escuro);margin-bottom:14px}
        .section-header p{font-size:clamp(.95rem,1.8vw,1.1rem);color:var(--cinza-texto);max-width:600px;margin:0 auto}
        .section-header .tag{display:inline-block;background:linear-gradient(135deg,rgba(79,70,229,.1),rgba(124,58,237,.1));color:var(--indigo);padding:6px 18px;border-radius:50px;font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px;border:1px solid rgba(79,70,229,.15)}
        .servicos{padding:100px 0;background:var(--cinza-claro)}
        .servicos__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:32px}
        .servico-card{background:var(--branco);border-radius:var(--raio);overflow:hidden;box-shadow:var(--sombra);border:1px solid rgba(79,70,229,.04);transition:var(--transicao);position:relative}
        .servico-card:hover{transform:translateY(-12px);box-shadow:var(--sombra-hover)}
        .servico-card__popular{position:absolute;top:16px;right:16px;background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco);padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:700;z-index:2;box-shadow:0 4px 12px rgba(79,70,229,.3)}
        .servico-card__img{width:100%;height:240px;object-fit:cover;transition:transform .5s ease}
        .servico-card:hover .servico-card__img{transform:scale(1.05)}
        .servico-card__img-wrap{overflow:hidden;position:relative}
        .servico-card__img-wrap::after{content:'';position:absolute;bottom:0;left:0;right:0;height:60px;background:linear-gradient(transparent,rgba(255,255,255,1))}
        .servico-card__body{padding:32px}
        .servico-card__cat{color:var(--indigo);font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px}
        .servico-card__title{font-size:1.5rem;font-weight:800;color:var(--titulo-escuro);margin-bottom:12px}
        .servico-card__desc{color:var(--cinza-texto);font-size:.92rem;line-height:1.7;margin-bottom:24px}
        .servico-card__features{list-style:none;margin-bottom:28px}
        .servico-card__features li{display:flex;align-items:flex-start;gap:12px;margin-bottom:12px;font-size:.88rem;color:var(--cinza-texto)}
        .servico-card__features li i{color:var(--whatsapp);margin-top:2px;min-width:18px}
        .servico-card__price{display:flex;align-items:baseline;gap:4px;margin-bottom:20px}
        .servico-card__price .cifrao{font-size:1.1rem;font-weight:700;color:var(--indigo)}
        .servico-card__price .valor{font-size:2.8rem;font-weight:900;color:var(--titulo-escuro);line-height:1}
        .servico-card__price .centavos{font-size:1rem;font-weight:600;color:var(--indigo);align-self:flex-start;margin-top:4px}
        .servico-card__price .periodo{font-size:.85rem;color:var(--cinza-texto);margin-left:4px;font-weight:500}
        .servico-card__price .obs{font-size:.75rem;color:#8892b0;display:block;margin-top:4px;font-weight:500}
        .btn-servico{width:100%;padding:16px;text-align:center;background:linear-gradient(135deg,var(--whatsapp),var(--whatsapp-hover));border-radius:50px;color:var(--branco);text-decoration:none;font-size:1rem;font-weight:800;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 6px 24px rgba(37,211,102,.3);transition:var(--bounce)}
        .btn-servico:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(37,211,102,.45)}
        .urgency{background:linear-gradient(135deg,var(--roxo-escuro),#2d1b69);padding:60px 0;text-align:center;color:var(--branco)}
        .urgency h3{font-size:clamp(1.4rem,3vw,2rem);font-weight:800;margin-bottom:12px}
        .urgency p{color:#b0b8cc;margin-bottom:28px;font-size:1.05rem}
        .urgency .btn-whatsapp{padding:16px 36px;font-size:1rem}
        .como-funciona{padding:100px 0;background:var(--branco)}
        .steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:32px;margin-top:50px}
        .step{text-align:center;position:relative}
        .step:not(:last-child)::after{content:'';position:absolute;top:40px;right:-16px;width:32px;height:2px;background:linear-gradient(90deg,var(--indigo),var(--violeta));opacity:.3}
        @media(max-width:768px){.step:not(:last-child)::after{display:none}}
        .step__num{width:80px;height:80px;margin:0 auto 20px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:1.8rem;font-weight:900;box-shadow:0 8px 24px rgba(79,70,229,.25);position:relative}
        .step__num::before{content:attr(data-step);position:absolute;font-size:3rem;font-weight:900;opacity:.08;top:50%;left:50%;transform:translate(-50%,-50%)}
        .step__title{font-size:1.15rem;font-weight:700;color:var(--titulo-escuro);margin-bottom:8px}
        .step__desc{font-size:.88rem;color:var(--cinza-texto);line-height:1.6}
        .comercios{padding:100px 0;background:var(--cinza-claro)}
        .comercios__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:28px}
        .comercio-card{background:var(--branco);border-radius:var(--raio);overflow:hidden;box-shadow:var(--sombra);border:1px solid rgba(79,70,229,.04);transition:var(--transicao);position:relative}
        .comercio-card:hover{transform:translateY(-10px);box-shadow:var(--sombra-hover)}
        .comercio-card__img-wrap{position:relative;height:220px;overflow:hidden}
        .comercio-card__img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease}
        .comercio-card:hover .comercio-card__img{transform:scale(1.08)}
        .comercio-card__overlay{position:absolute;inset:0;background:linear-gradient(transparent 40%,rgba(26,16,60,.85));display:flex;align-items:flex-end;padding:20px}
        .comercio-card__categoria{position:absolute;top:16px;left:16px;background:rgba(255,255,255,.95);padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:700;color:var(--indigo);text-transform:uppercase;letter-spacing:.5px;backdrop-filter:blur(10px)}
        .comercio-card__nome{color:var(--branco);font-size:1.3rem;font-weight:800;text-shadow:0 2px 10px rgba(0,0,0,.3)}
        .comercio-card__body{padding:24px}
        .comercio-card__desc{font-size:.88rem;color:var(--cinza-texto);line-height:1.7;margin-bottom:16px;min-height:60px}
        .comercio-card__tags{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px}
        .comercio-card__tags span{background:rgba(79,70,229,.06);color:var(--indigo);padding:4px 12px;border-radius:50px;font-size:.72rem;font-weight:600}
        .comercio-card__footer{display:flex;align-items:center;justify-content:space-between}
        .comercio-card__status{display:flex;align-items:center;gap:6px;font-size:.8rem;font-weight:600;color:var(--whatsapp)}
        .comercio-card__status i{font-size:.6rem;animation:pulse-dot 2s infinite}
        @keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}
        .btn-ver-site{padding:10px 20px;background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco);text-decoration:none;border-radius:50px;font-size:.82rem;font-weight:700;transition:var(--bounce);box-shadow:0 4px 15px rgba(79,70,229,.25)}
        .btn-ver-site:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(79,70,229,.4)}
        .filtros{padding:40px 0 20px;background:var(--cinza-claro);border-bottom:1px solid rgba(79,70,229,.06)}
        .filtros__wrap{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
        .filtro-btn{padding:10px 24px;border-radius:50px;border:1px solid rgba(79,70,229,.15);background:var(--branco);color:var(--cinza-texto);font-family:'Poppins',sans-serif;font-size:.85rem;font-weight:600;cursor:pointer;transition:var(--transicao)}
        .filtro-btn:hover,.filtro-btn.active{background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco);border-color:transparent;box-shadow:0 4px 15px rgba(79,70,229,.25)}
        .depoimentos{padding:100px 0;background:linear-gradient(180deg,var(--cinza-claro),var(--branco))}
        .depoimentos__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:28px}
        .depo-card{background:var(--branco);padding:32px;border-radius:var(--raio);box-shadow:var(--sombra);border:1px solid rgba(79,70,229,.03);transition:var(--transicao);position:relative}
        .depo-card:hover{transform:translateY(-6px);box-shadow:var(--sombra-hover)}
        .depo-card__quote{position:absolute;top:20px;right:24px;font-size:3rem;color:rgba(79,70,229,.08);font-family:Georgia,serif;line-height:1}
        .depo-card__text{font-style:italic;margin-bottom:24px;color:var(--cinza-texto);font-size:.92rem;line-height:1.75;position:relative;z-index:1}
        .depo-card__stars{color:#fbbf24;margin-bottom:16px;font-size:.9rem}
        .depo-card__author{display:flex;align-items:center;gap:14px}
        .depo-card__avatar{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--indigo),var(--violeta));display:flex;align-items:center;justify-content:center;color:var(--branco);font-weight:700;font-size:1rem}
        .depo-card__name{font-size:1rem;font-weight:700;color:var(--titulo-escuro)}
        .depo-card__biz{font-size:.82rem;color:var(--cinza-texto);font-weight:500}
        .faq{padding:100px 0;background:var(--cinza-claro)}
        .faq__item{background:var(--branco);border-radius:var(--raio);padding:24px 32px;margin-bottom:16px;box-shadow:var(--sombra);cursor:pointer;transition:var(--transicao)}
        .faq__item:hover{box-shadow:0 8px 24px rgba(79,70,229,.1)}
        .faq__pergunta{font-size:1.1rem;font-weight:600;color:var(--titulo-escuro);display:flex;justify-content:space-between;align-items:center}
        .faq__pergunta i{transition:transform .3s}
        .faq__resposta{max-height:0;overflow:hidden;transition:max-height .4s ease,padding-top .3s ease;color:var(--cinza-texto);font-size:.95rem;line-height:1.6}
        .faq__item.active .faq__resposta{max-height:300px;padding-top:16px}
        .faq__item.active .faq__pergunta i{transform:rotate(180deg)}
        .cta-final{padding:100px 0;background:linear-gradient(165deg,#1a103c,#2d1b69,#1e1b4b);text-align:center;position:relative;overflow:hidden}
        .cta-final::before{content:'';position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.12),transparent 70%);top:-150px;left:-150px;border-radius:50%}
        .cta-final .container{position:relative;z-index:2}
        .cta-final h2{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:var(--branco);margin-bottom:16px}
        .cta-final p{color:#b0b8cc;font-size:1.1rem;margin-bottom:36px;max-width:550px;margin-left:auto;margin-right:auto}
        .cta-final .btn-whatsapp{padding:20px 48px;font-size:1.15rem}
        .cta-final__garantia{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:20px;color:#8892b0;font-size:.85rem}
        .cta-final__garantia i{color:#a78bfa}
        .footer{background:#0a0620;color:#8892b0;padding:60px 0 24px}
        .footer__top{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:40px;margin-bottom:40px}
        .footer__brand .logo__text{color:var(--branco);margin-bottom:12px;display:block}
        .footer__brand p{font-size:.88rem;line-height:1.7;max-width:300px}
        .footer__links h4{color:var(--branco);font-size:.95rem;margin-bottom:16px}
        .footer__links a{display:block;color:#8892b0;text-decoration:none;font-size:.85rem;margin-bottom:10px;transition:color .3s}
        .footer__links a:hover{color:var(--violeta)}
        .footer__bottom{text-align:center;padding-top:24px;border-top:1px solid rgba(255,255,255,.06);font-size:.82rem}
        .wpp-float{position:fixed;bottom:24px;right:24px;z-index:9999;width:60px;height:60px;background:var(--whatsapp);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(37,211,102,.5);transition:var(--bounce);text-decoration:none}
        .wpp-float:hover{transform:scale(1.12) translateY(-3px);box-shadow:0 12px 36px rgba(37,211,102,.65)}
        .wpp-float i{font-size:1.9rem;color:var(--branco)}
        .wpp-float__pulse{position:absolute;width:100%;height:100%;border-radius:50%;background:rgba(37,211,102,.4);animation:pulse 2s ease-out infinite}
        @keyframes pulse{0%{transform:scale(1);opacity:.8}100%{transform:scale(1.7);opacity:0}}
        .back-to-top{position:fixed;bottom:100px;right:24px;width:48px;height:48px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--branco);text-decoration:none;opacity:0;visibility:hidden;transition:all .3s ease;z-index:9998;box-shadow:0 4px 15px rgba(79,70,229,.3)}
        .back-to-top.visible{opacity:1;visibility:visible}
        .back-to-top:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(79,70,229,.4)}
        .fade-up{opacity:0;transform:translateY(40px);transition:all .7s ease-out}
        .fade-up.visible{opacity:1;transform:translateY(0)}
        @media(max-width:768px){
            .nav-links{display:none}
            .menu-toggle{display:block}
            .hero__stats{gap:24px}
            .hero__stat-num{font-size:1.6rem}
            .hero__cta-group{flex-direction:column;align-items:flex-start}
            .steps{grid-template-columns:1fr}
            .step:not(:last-child)::after{display:none}
            .footer__top{flex-direction:column}
            .comercios__grid{grid-template-columns:1fr}
            .filtros__wrap{gap:8px}
            .filtro-btn{padding:8px 16px;font-size:.8rem}
        }
    </style>
</head>
