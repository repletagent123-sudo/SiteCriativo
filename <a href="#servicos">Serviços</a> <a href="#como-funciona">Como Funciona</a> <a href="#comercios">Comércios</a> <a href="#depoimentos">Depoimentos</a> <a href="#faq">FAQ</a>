.cta-final{padding:90px 0;background:linear-gradient(165deg,#1a103c,#2d1b69,#1e1b4b);text-align:center;position:relative;overflow:hidden}
.cta-final::before{content:'';position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.18),transparent 70%);top:-150px;left:-150px;border-radius:50%;animation:float 8s ease-in-out infinite}
.cta-final::after{content:'';position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(79,70,229,.15),transparent 70%);bottom:-100px;right:-100px;border-radius:50%;animation:float 10s ease-in-out infinite reverse}
.cta-final .container{position:relative;z-index:2}
.cta-final h2{font-size:clamp(1.9rem,4vw,2.8rem);font-weight:900;color:var(--branco);margin-bottom:16px;line-height:1.15}
