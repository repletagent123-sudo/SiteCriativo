.wpp-float-wrapper{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;gap:12px}
.wpp-tooltip{background:var(--branco);padding:12px 18px;border-radius:14px 14px 4px 14px;box-shadow:0 10px 30px rgba(0,0,0,.18);max-width:280px;opacity:0;transform:translateY(10px) scale(.95);visibility:hidden;transition:all .4s cubic-bezier(.175,.885,.32,1.275);position:relative;border:1px solid rgba(79,70,229,.1)}
.wpp-tooltip.show{opacity:1;transform:translateY(0) scale(1);visibility:visible}
.wpp-tooltip__close{position:absolute;top:6px;right:8px;width:20px;height:20px;border-radius:50%;background:rgba(0,0,0,.06);color:var(--cinza-texto);font-size:.7rem;display:flex;align-items:center;justify-content:center;cursor:pointer}
.wpp-tooltip__title{font-weight:700;color:var(--titulo-escuro);font-size:.9rem;margin-bottom:4px;display:flex;align-items:center;gap:6px}
.wpp-tooltip__title i{color:var(--whatsapp)}
.wpp-tooltip__text{font-size:.78rem;color:var(--cinza-texto);line-height:1.5}
.wpp-tooltip__cta{display:inline-block;margin-top:8px;color:var(--whatsapp);font-weight:700;font-size:.8rem}
.wpp-options{position:absolute;bottom:78px;right:0;display:flex;flex-direction:column;gap:8px;opacity:0;transform:translateY(10px) scale(.95);visibility:hidden;transition:all .3s cubic-bezier(.175,.885,.32,1.275);transform-origin:bottom right}
.wpp-options.open{opacity:1;transform:translateY(0) scale(1);visibility:visible}
.wpp-options a{display:flex;align-items:center;gap:10px;background:var(--branco);padding:10px 18px;border-radius:50px;box-shadow:0 6px 20px rgba(0,0,0,.12);font-size:.85rem;font-weight:600;color:var(--titulo-escuro);white-space:nowrap;transition:var(--transicao);border:1px solid rgba(79,70,229,.08)}
.wpp-options a:hover{background:var(--whatsapp);color:var(--branco);transform:translateX(-4px)}
.wpp-options a i{font-size:1rem;color:var(--violeta)}
.wpp-options a:hover i{color:var(--branco)}
.wpp-float{position:relative;width:64px;height:64px;background:var(--whatsapp);border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 30px rgba(37,211,102,.5);transition:var(--bounce);cursor:pointer;border:none}
.wpp-float:hover{transform:scale(1.12) translateY(-3px);box-shadow:0 14px 40px rgba(37,211,102,.65)}
.wpp-float.open{transform:rotate(45deg) scale(1.05);background:#ef4444;box-shadow:0 8px 30px rgba(239,68,68,.5)}
.wpp-float i{font-size:1.9rem;color:var(--branco);transition:transform .3s}
.wpp-float__pulse{position:absolute;width:100%;height:100%;border-radius:50%;background:rgba(37,211,102,.4);animation:pulse 2s ease-out infinite;pointer-events:none}
@keyframes pulse{0%{transform:scale(1);opacity:.8}100%{transform:scale(1.8);opacity:0}}
.wpp-badge{position:absolute;top:-4px;right:-4px;min-width:22px;height:22px;background:#ef4444;color:var(--branco);border-radius:50px;font-size:.7rem;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 6px;box-shadow:0 2px 8px rgba(239,68,68,.4);border:2px solid var(--branco);opacity:0;transform:scale(0);transition:all .3s cubic-bezier(.175,.885,.32,1.275)}
.wpp-badge.show{opacity:1;transform:scale(1)}

/* ===== BACK TO TOP ===== */
.back-to-top{position:fixed;bottom:104px;right:30px;width:46px;height:46px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--branco);opacity:0;visibility:hidden;transition:all .3s ease;z-index:9998;box-shadow:0 4px 15px rgba(79,70,229,.3);border:none;cursor:pointer}
.back-to-top.visible{opacity:1;visibility:visible}
.back-to-top:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(79,70,229,.4)}

/* ===== ANIMAÇÕES ===== */
.fade-up{opacity:0;transform:translateY(40px);transition:opacity .8s ease-out,transform .8s ease-out}
.fade-up.visible{opacity:1;transform:translateY(0)}
.fade-up.delay-1{transition-delay:.1s}
.fade-up.delay-2{transition-delay:.2s}
.fade-up.delay-3{transition-delay:.3s}

