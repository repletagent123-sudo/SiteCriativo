<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --roxo-escuro:#1a103c;
  --roxo-medio:#2d1b69;
  --indigo:#4f46e5;
  --violeta:#7c3aed;
  --violeta-claro:#a78bfa;
  --violeta-mais-claro:#c4b5fd;
  --branco:#ffffff;
  --cinza-claro:#f8f9fc;
  --cinza-texto:#5a5d6e;
  --cinza-mute:#8892b0;
  --titulo-escuro:#1a103c;
  --whatsapp:#25D366;
  --whatsapp-hover:#1ebe5b;
  --whatsapp-soft:rgba(37,211,102,.1);
  --sombra:0 12px 32px rgba(79,70,229,.06);
  --sombra-hover:0 20px 48px rgba(79,70,229,.14);
  --sombra-wpp:0 10px 40px rgba(37,211,102,.45);
  --raio:20px;
  --raio-sm:12px;
  --transicao:all .35s cubic-bezier(.4,0,.2,1);
  --bounce:all .45s cubic-bezier(.175,.885,.32,1.275);
  --container:1200px;
}
html{scroll-behavior:smooth;font-size:16px;-webkit-text-size-adjust:100%}
body{font-family:'Poppins',sans-serif;background:var(--branco);color:var(--cinza-texto);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{max-width:100%;display:block;height:auto}
a{text-decoration:none;color:inherit}
button{font-family:inherit;cursor:pointer;border:none;background:none}
.container{width:100%;max-width:var(--container);margin:0 auto;padding:0 24px}
::-webkit-scrollbar{width:8px}
::-webkit-scrollbar-track{background:#f1f1f1}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--indigo),var(--violeta));border-radius:10px}
::selection{background:var(--violeta);color:var(--branco)}

/* ===== HEADER ===== */
.header{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:14px 0;background:rgba(255,255,255,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);transition:var(--transicao);border-bottom:1px solid transparent}
.header.scrolled{background:rgba(255,255,255,.97);box-shadow:0 4px 30px rgba(0,0,0,.08);border-bottom-color:rgba(79,70,229,.06);padding:10px 0}
.header .container{display:flex;align-items:center;justify-content:space-between;gap:20px}
.logo{display:flex;align-items:center;gap:10px}
.logo__icon{width:44px;height:44px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:14px;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:18px;font-weight:800;box-shadow:0 4px 15px rgba(79,70,229,.3);transition:var(--bounce)}
.logo:hover .logo__icon{transform:rotate(-8deg) scale(1.05)}
.logo__text{font-size:1.4rem;font-weight:800;color:var(--roxo-escuro);line-height:1}
.logo__text span{color:var(--violeta)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{color:var(--titulo-escuro);font-weight:600;font-size:.92rem;transition:var(--transicao);position:relative;padding:4px 0}
.nav-links a:not(.btn-nav)::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:linear-gradient(90deg,var(--indigo),var(--violeta));transition:width .3s;border-radius:2px}
.nav-links a:not(.btn-nav):hover::after{width:100%}
.btn-nav{padding:10px 24px;background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco)!important;border-radius:50px;font-weight:700;font-size:.9rem;box-shadow:0 4px 18px rgba(124,58,237,.3);transition:var(--bounce);display:inline-flex;align-items:center;gap:8px}
.btn-nav:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(124,58,237,.45)}
.btn-nav i{font-size:1rem}
.menu-toggle{display:none;background:none;font-size:1.5rem;color:var(--roxo-escuro);width:40px;height:40px;border-radius:10px;align-items:center;justify-content:center;transition:background .2s}
.menu-toggle:hover{background:rgba(79,70,229,.08)}

/* Mobile menu */
.mobile-menu{position:fixed;top:0;right:-100%;width:min(320px,85vw);height:100dvh;background:var(--branco);z-index:2000;box-shadow:-10px 0 40px rgba(0,0,0,.15);transition:right .4s cubic-bezier(.4,0,.2,1);padding:80px 24px 24px;display:flex;flex-direction:column;gap:8px}
.mobile-menu.open{right:0}
.mobile-menu__close{position:absolute;top:20px;right:20px;width:40px;height:40px;border-radius:10px;background:rgba(79,70,229,.08);color:var(--roxo-escuro);font-size:1.2rem;display:flex;align-items:center;justify-content:center}
.mobile-menu a{padding:14px 16px;border-radius:12px;font-weight:600;color:var(--titulo-escuro);transition:background .2s;font-size:1rem;display:flex;align-items:center;gap:12px}
.mobile-menu a:hover{background:rgba(79,70,229,.06)}
.mobile-menu a i{color:var(--violeta);width:20px}
.mobile-menu__cta{margin-top:auto;background:linear-gradient(135deg,var(--whatsapp),var(--whatsapp-hover))!important;color:var(--branco)!important;justify-content:center;font-weight:700;box-shadow:0 6px 20px rgba(37,211,102,.35);padding:16px!important}
.mobile-menu__overlay{position:fixed;inset:0;background:rgba(26,16,60,.5);z-index:1999;opacity:0;visibility:hidden;transition:all .3s;backdrop-filter:blur(4px)}
.mobile-menu__overlay.open{opacity:1;visibility:visible}

/* ===== HERO ===== */
.hero{padding:140px 0 80px;background:linear-gradient(165deg,#1a103c 0%,#2d1b69 25%,#1e1b4b 55%,#0a0620 100%);position:relative;overflow:hidden;min-height:100vh;display:flex;align-items:center}
.hero__bg{position:absolute;inset:0;pointer-events:none}
.hero__bg::before{content:'';position:absolute;inset:0;background-image:radial-gradient(circle,rgba(255,255,255,.05) 1px,transparent 1px);background-size:50px 50px;opacity:.6}
.hero__bg::after{content:'';position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(124,58,237,.18),transparent 70%);top:-200px;right:-200px;border-radius:50%;animation:float 8s ease-in-out infinite}
.hero__bg-glow{position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(79,70,229,.15),transparent 70%);bottom:-100px;left:-100px;border-radius:50%;animation:float 10s ease-in-out infinite reverse}
@keyframes float{0%,100%{transform:translate(0,0)}50%{transform:translate(20px,-20px)}}
.hero .container{position:relative;z-index:2}
.hero__badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);padding:8px 18px;border-radius:50px;color:var(--violeta-mais-claro);font-size:.82rem;font-weight:600;margin-bottom:24px;backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px)}
.hero__badge i{color:var(--violeta-claro);animation:bolt 2s ease-in-out infinite}
@keyframes bolt{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
.hero__title{font-size:clamp(2.2rem,5.5vw,4.2rem);font-weight:900;color:var(--branco);line-height:1.08;margin-bottom:20px;max-width:880px;letter-spacing:-.02em}
.hero__title .highlight{background:linear-gradient(90deg,#a78bfa,#c4b5fd,#ddd6fe);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:200% auto;animation:shimmer 4s linear infinite}
@keyframes shimmer{to{background-position:200% center}}
.hero__subtitle{font-size:clamp(1rem,2vw,1.2rem);color:#b0b8cc;max-width:640px;margin-bottom:36px;line-height:1.7}
.hero__stats{display:flex;gap:36px;margin-bottom:36px;flex-wrap:wrap}
.hero__stat{text-align:left}
.hero__stat-num{font-size:1.9rem;font-weight:900;color:var(--branco);line-height:1;display:flex;align-items:baseline;gap:2px}
.hero__stat-num span{font-size:.5em;vertical-align:super;color:var(--violeta-claro);font-weight:800}
.hero__stat-label{font-size:.78rem;color:#8892b0;margin-top:4px;font-weight:500}
.hero__cta-group{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.btn-whatsapp{display:inline-flex;align-items:center;gap:12px;background:linear-gradient(135deg,var(--whatsapp),var(--whatsapp-hover));color:var(--branco);padding:18px 36px;border-radius:50px;font-weight:800;font-size:1.05rem;box-shadow:var(--sombra-wpp);transition:var(--bounce);border:none;cursor:pointer;font-family:inherit}
.btn-whatsapp:hover{transform:translateY(-3px) scale(1.02);box-shadow:0 14px 50px rgba(37,211,102,.6)}
.btn-whatsapp:active{transform:translateY(-1px) scale(.99)}
.btn-whatsapp i{font-size:1.3rem}
.btn-ghost{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:var(--branco);padding:18px 30px;border-radius:50px;font-weight:600;font-size:1rem;backdrop-filter:blur(10px);transition:var(--transicao)}
.btn-ghost:hover{background:rgba(255,255,255,.14);transform:translateY(-2px)}
.hero__trust{display:flex;align-items:center;gap:12px;color:#8892b0;font-size:.85rem}
.hero__trust-avatars{display:flex}
.hero__trust-avatars span{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--indigo),var(--violeta));border:2px solid #1a103c;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:.7rem;font-weight:700;margin-left:-10px}
.hero__trust-avatars span:first-child{margin-left:0}
.hero__live{display:inline-flex;align-items:center;gap:8px;background:rgba(37,211,102,.12);border:1px solid rgba(37,211,102,.3);padding:6px 14px;border-radius:50px;font-size:.78rem;font-weight:600;color:#86efac;margin-left:12px}
.hero__live-dot{width:8px;height:8px;border-radius:50%;background:var(--whatsapp);box-shadow:0 0 12px var(--whatsapp);animation:pulse-dot 1.5s infinite}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.3)}}

/* ===== PROOF BAR ===== */
.proof-bar{background:linear-gradient(90deg,var(--indigo),var(--violeta));padding:14px 0;text-align:center;color:var(--branco);font-size:.88rem;font-weight:600;position:relative;overflow:hidden}
.proof-bar::before{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.1),transparent);animation:shine 3s linear infinite}
@keyframes shine{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
.proof-bar__inner{position:relative;z-index:1;display:flex;justify-content:center;align-items:center;flex-wrap:wrap;gap:8px 24px}
.proof-bar span{display:inline-flex;align-items:center;gap:6px}
.proof-bar i{color:var(--violeta-mais-claro)}

/* ===== SECTION HEADERS ===== */
.section{padding:90px 0;position:relative}
.section--alt{background:var(--cinza-claro)}
.section-header{text-align:center;margin-bottom:60px}
.section-header h2{font-size:clamp(1.8rem,4vw,2.6rem);font-weight:800;color:var(--titulo-escuro);margin-bottom:14px;line-height:1.15;letter-spacing:-.01em}
.section-header p{font-size:clamp(.95rem,1.8vw,1.1rem);color:var(--cinza-texto);max-width:620px;margin:0 auto}
.section-header .tag{display:inline-block;background:linear-gradient(135deg,rgba(79,70,229,.1),rgba(124,58,237,.1));color:var(--indigo);padding:6px 18px;border-radius:50px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:14px;border:1px solid rgba(79,70,229,.15)}

/* ===== SERVIÇOS ===== */
.servicos__grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:28px}
.servico-card{background:var(--branco);border-radius:var(--raio);overflow:hidden;box-shadow:var(--sombra);border:1px solid rgba(79,70,229,.04);transition:var(--transicao);position:relative;display:flex;flex-direction:column}
.servico-card:hover{transform:translateY(-10px);box-shadow:var(--sombra-hover)}
.servico-card--featured{border:2px solid var(--violeta);box-shadow:0 20px 50px rgba(124,58,237,.18)}
.servico-card__popular{position:absolute;top:16px;right:16px;background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco);padding:5px 14px;border-radius:50px;font-size:.7rem;font-weight:700;z-index:2;box-shadow:0 4px 12px rgba(79,70,229,.3);text-transform:uppercase;letter-spacing:.5px}
.servico-card__img-wrap{overflow:hidden;position:relative;aspect-ratio:16/10}
.servico-card__img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.servico-card:hover .servico-card__img{transform:scale(1.06)}
.servico-card__img-wrap::after{content:'';position:absolute;bottom:0;left:0;right:0;height:60px;background:linear-gradient(transparent,rgba(255,255,255,1));pointer-events:none}
.servico-card__body{padding:30px;display:flex;flex-direction:column;flex:1}
.servico-card__cat{color:var(--indigo);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;display:flex;align-items:center;gap:6px}
.servico-card__cat i{color:var(--violeta)}
.servico-card__title{font-size:1.4rem;font-weight:800;color:var(--titulo-escuro);margin-bottom:12px;line-height:1.2}
.servico-card__desc{color:var(--cinza-texto);font-size:.9rem;line-height:1.7;margin-bottom:22px}
.servico-card__features{list-style:none;margin-bottom:26px;flex:1}
.servico-card__features li{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:.85rem;color:var(--cinza-texto);line-height:1.5}
.servico-card__features li i{color:var(--whatsapp);margin-top:2px;min-width:16px}
.servico-card__price{display:flex;align-items:baseline;flex-wrap:wrap;gap:4px;margin-bottom:18px;padding:16px;background:linear-gradient(135deg,rgba(79,70,229,.04),rgba(124,58,237,.04));border-radius:var(--raio-sm);border:1px dashed rgba(79,70,229,.2)}
.servico-card__price .cifrao{font-size:1rem;font-weight:700;color:var(--indigo)}
.servico-card__price .valor{font-size:2.4rem;font-weight:900;color:var(--titulo-escuro);line-height:1}
.servico-card__price .centavos{font-size:.9rem;font-weight:600;color:var(--indigo);align-self:flex-start;margin-top:4px}
.servico-card__price .obs{font-size:.72rem;color:var(--cinza-mute);width:100%;margin-top:6px;font-weight:500}
.servico-card__price .obs s{opacity:.6;margin-right:6px}
.servico-card__price .obs strong{color:var(--whatsapp);font-weight:700}
.btn-servico{width:100%;padding:15px;background:linear-gradient(135deg,var(--whatsapp),var(--whatsapp-hover));border-radius:50px;color:var(--branco);font-size:.95rem;font-weight:800;display:flex;align-items:center;justify-content:center;gap:10px;box-shadow:0 6px 24px rgba(37,211,102,.3);transition:var(--bounce);border:none;cursor:pointer;font-family:inherit}
.btn-servico:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(37,211,102,.45)}

/* ===== COMO FUNCIONA ===== */
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:32px;margin-top:50px;position:relative}
.step{text-align:center;position:relative;padding:0 12px}
.step:not(:last-child)::after{content:'';position:absolute;top:40px;right:-22px;width:44px;height:2px;background:linear-gradient(90deg,var(--indigo),var(--violeta));opacity:.4}
.step__num{width:80px;height:80px;margin:0 auto 22px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--branco);font-size:1.8rem;font-weight:900;box-shadow:0 8px 24px rgba(79,70,229,.25);position:relative;transition:var(--bounce)}
.step:hover .step__num{transform:scale(1.08) rotate(-5deg)}
.step__num::before{content:attr(data-step);position:absolute;font-size:3.5rem;font-weight:900;opacity:.1;top:50%;left:50%;transform:translate(-50%,-50%);z-index:0}
.step__num>*{position:relative;z-index:1}
.step__title{font-size:1.15rem;font-weight:700;color:var(--titulo-escuro);margin-bottom:8px}
.step__desc{font-size:.88rem;color:var(--cinza-texto);line-height:1.65}

/* ===== RESULTADOS / NÚMEROS ===== */
.resultados{background:linear-gradient(165deg,var(--roxo-escuro),var(--roxo-medio),#1e1b4b);color:var(--branco);position:relative;overflow:hidden}
.resultados::before{content:'';position:absolute;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.15),transparent 70%);top:-150px;right:-150px;border-radius:50%}
.resultados::after{content:'';position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(79,70,229,.12),transparent 70%);bottom:-100px;left:-100px;border-radius:50%}
.resultados .container{position:relative;z-index:2}
.resultados .section-header h2{color:var(--branco)}
.resultados .section-header p{color:#b0b8cc}
.resultados .section-header .tag{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:var(--violeta-mais-claro)}
.numeros-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:24px;margin-top:20px}
.numero-card{text-align:center;padding:32px 20px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:var(--raio);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);transition:var(--transicao)}
.numero-card:hover{transform:translateY(-6px);background:rgba(255,255,255,.07);border-color:rgba(255,255,255,.2)}
.numero-card__icon{width:56px;height:56px;margin:0 auto 16px;background:linear-gradient(135deg,var(--indigo),var(--violeta));border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:1.4rem}
.numero-card__num{font-size:2.6rem;font-weight:900;line-height:1;background:linear-gradient(90deg,#a78bfa,#c4b5fd);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.numero-card__label{font-size:.85rem;color:#b0b8cc;margin-top:8px;font-weight:500}

/* ===== COMÉRCIOS / CASES ===== */
.filtros{padding:30px 0 0;background:var(--cinza-claro)}
.filtros__wrap{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.filtro-btn{padding:9px 22px;border-radius:50px;border:1px solid rgba(79,70,229,.15);background:var(--branco);color:var(--cinza-texto);font-family:'Poppins',sans-serif;font-size:.85rem;font-weight:600;transition:var(--transicao);display:inline-flex;align-items:center;gap:6px}
.filtro-btn:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(79,70,229,.1)}
.filtro-btn.active{background:linear-gradient(135deg,var(--indigo),var(--violeta));color:var(--branco);border-color:transparent;box-shadow:0 4px 15px rgba(79,70,229,.3)}
.comercios__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:26px;margin-top:30px}
.comercio-card{background:var(--branco);border-radius:var(--raio);overflow:hidden;box-shadow:var(--sombra);border:1px solid rgba(79,70,229,.04);transition:var(--transicao);position:relative}
.comercio-card.hidden{display:none}
.comercio-card:hover{transform:translateY(-8px);box-shadow:var(--sombra-hover)}
.comercio-card__img-wrap{position:relative;aspect-ratio:16/10;overflow:hidden}
.comercio-card__img{width:100%;height:100%;object-fit:cover;transition:transform .6s ease}
.comercio-card:hover .comercio-card__img{transform:scale(1.08)}
.comercio-card__overlay{position:absolute;inset:0;background:linear-gradient(transparent 30%,rgba(26,16,60,.92));display:flex;align-items:flex-end;padding:18px}
.comercio-card__categoria{position:absolute;top:14px;left:14px;background:rgba(255,255,255,.95);padding:5px 12px;border-radius:50px;font-size:.7rem;font-weight:700;color:var(--indigo);text-transform:uppercase;letter-spacing:.5px;backdrop-filter:blur(10px)}
