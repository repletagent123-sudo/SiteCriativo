.footer__bottom{text-align:center;padding-top:24px;border-top:1px solid rgba(255,255,255,.06);font-size:.82rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.footer__bottom a{color:var(--violeta-claro);font-weight:500}

